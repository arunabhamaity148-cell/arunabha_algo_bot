# ══════════════════════════════════════════════════════════════
# ARUNABHA ALGO BOT — .env Template
# Windows 11 + Python 3.11 compatible
# ══════════════════════════════════════════════════════════════

# ── Windows Encoding Fix (MUST be first) ──────────────────────
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

# ── Telegram (mandatory) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Binance API ───────────────────────────────────────────────
# Paper mode-এ খালি রাখো
BINANCE_API_KEY=
BINANCE_SECRET=

# Testnet use করতে চাইলে (recommended for live testing):
# BINANCE_API_KEY=testnet_key_here
# BINANCE_SECRET=testnet_secret_here

# ── Capital & Risk ────────────────────────────────────────────
ACCOUNT_SIZE=100000
RISK_PER_TRADE=1.0
MAX_LEVERAGE=15

# ── Mode ──────────────────────────────────────────────────────
ENVIRONMENT=development
# development = paper trades, no real orders
# production  = live trading (API key required)

PAPER_TRADING=true
# true  = simulate trades, no real orders
# false = real orders (set ENVIRONMENT=production too)

LOG_LEVEL=INFO

# ── Redis — Windows-এ বন্ধ রাখো ──────────────────────────────
USE_REDIS=false
REDIS_URL=
# USE_REDIS=true করতে হলে: pip install redis
# তারপর REDIS_URL=redis://localhost:6379

# ── Session Size Multipliers (optional override) ───────────────
SIZE_MULT_LONDON=1.2
SIZE_MULT_NY=1.2
SIZE_MULT_ASIA=0.7
SIZE_MULT_HIGH_VOL=0.8

# ── Server ────────────────────────────────────────────────────
PORT=8080
WEBHOOK_SECRET=change-this-to-random-string

# ══════════════════════════════════════════════════════════════
# Windows-এ চালানোর নিয়ম:
#
# 1. এই ফাইল copy করো → .env নামে save করো (same folder-এ)
# 2. TELEGRAM_BOT_TOKEN ও CHAT_ID দাও
# 3. cmd/PowerShell-এ:
#    set PYTHONIOENCODING=utf-8
#    set PYTHONUTF8=1
#    python main.py --mode web
#
# অথবা PowerShell-এ:
#    $env:PYTHONIOENCODING="utf-8"
#    $env:PYTHONUTF8="1"
#    python main.py --mode web
# ══════════════════════════════════════════════════════════════